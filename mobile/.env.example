# Mobile app configuration.
# Copy to .env. EXPO_PUBLIC_-prefixed vars are inlined at build time.

# Base URL of the Go backend.
#   Web / iOS simulator: http://localhost:8080
#   Android emulator:    http://10.0.2.2:8080
#   Physical device:     http://<your-computer-LAN-IP>:8080
# EXPO_PUBLIC_API_URL=http://localhost:8080
# <
# Replace 192.168.1.X with your actual computer LAN IP
EXPO_PUBLIC_API_URL=http://192.x.x.x:8080