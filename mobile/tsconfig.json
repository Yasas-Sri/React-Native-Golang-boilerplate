{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    // Set explicitly so editors that don't fully resolve the extended Expo
    // config (e.g. an older bundled TypeScript) still enable JSX and stop
    // reporting "Cannot use JSX unless the '--jsx' flag is provided".
    "jsx": "react-jsx",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
